</edge>
<edge source="tenues_de_travail" target="entretien_en_interne">
  <data key="d2">HAS_RULE</data>
</edge>
<edge source="entretien_en_interne" target="specification_temperature_lavage">
  <data key="d2">HAS_SPECIFICATION</data>
</edge>
<edge source="entretien_en_interne" target="specification_nombre_lavages">
