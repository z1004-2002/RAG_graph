  <data key="d1">Rule_Instruction</data>
</node>
<node id="entretien_par_prestataire">
  <data key="d0">Faire entretenir les vêtements de travail par un prestataire de service</data>
  <data key="d1">Rule_Instruction</data>
</node>
<node id="tenues_enlevees_regulierement_entretien">
  <data key="d0">Les tenues doivent être enlevées régulièrement pour entretien</data>
  <data key="d1">Rule_Instruction</data>
</node>
<node id="entretien_en_interne">
  <data key="d0">Effectuer l'entretien des tenues en interne</data>
  <data key="d1">Rule_Instruction</data>
</node>
<node id="specification_temperature_lavage">
  <data key="d0">Température de lavage</data>
  <data key="d1">Specification</data>
</node>
<node id="specification_nombre_lavages">
  <data key="d0">Nombre de lavages</data>
  <data key="d1">Specification</data>
</node>
<edge source="tenues_de_travail" target="employeur_louer_vetements">
  <data key="d2">HAS_RULE</data>
</edge>
<edge source="tenues_de_travail" target="fournisseur_entretien_maintenance">
  <data key="d2">HAS_RULE</data>
</edge>
<edge source="tenues_de_travail" target="entretien_par_prestataire">
  <data key="d2">HAS_RULE</data>
</edge>
<edge source="tenues_de_travail" target="tenues_enlevees_regulierement_entretien">
